{
  "name": "nail-art-booking",
  "version": "1.0.0",
  "description": "Nail Art Advertisement & Booking Website - Full Stack Next.js Project",
  "main": "server/server.js",
  "type": "module",
  "scripts": {
    "dev:server": "node --watch-path=server/config --watch-path=server/controllers --watch-path=server/middleware --watch-path=server/models --watch-path=server/routes --watch-path=server/utils --watch-path=server/server.js server/server.js",
    "dev:client": "next dev",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "build": "next build",
    "start:client": "next start",
    "start": "node server/server.js",
    "seed": "node server/utils/seed.js",
    "migrate": "node server/utils/migrate.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-fileupload": "^1.5.0",
    "framer-motion": "^11.2.10",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.395.0",
    "mongoose": "^8.4.1",
    "next": "^14.2.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3"
  }
}
